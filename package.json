	"license": "MIT",
	"engines": {
		"node": ">=20.19.0"
	},
	"workspaces": [
		"shared",
		"server",
		"client"
	],
	"scripts": {
		"spellcheck": "cspell .",
		"lint": "eslint",
		"lint:fix": "eslint --fix",
